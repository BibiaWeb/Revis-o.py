#Crie uma lista com 6 notas (ex: [5.5, 8.0, 4.0, 9.5, 6.0, 3.5]).
#Utilize um laço for para percorrer a lista e imprimir apenas 
#as notas que são maiores ou iguais a 6.

notas = {5.5, 8.0, 4.0, 9.5, 6.0, 3.5}

print("Notas de aprovados (maior ou igual a 6):")

for nota in notas:
    if nota >= 6:
        print(nota)
